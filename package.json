{
  "name": "va-framework",
  "private": true,
  "version": "2.3.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently -n web,api -c cyan,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/api --reload --host 127.0.0.1 --port 8000",
    "dev:web": "pnpm --filter @va/web dev",
    "dev:web:turbo": "pnpm --filter @va/web dev:turbo",
    "lint": "turbo run lint",
    "test": "turbo run test && python -m pytest apps/api/tests",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "turbo": "2.9.1"
  }
}
